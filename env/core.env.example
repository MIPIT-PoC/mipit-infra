NODE_ENV=development
PORT=8080
DATABASE_URL=postgresql://mipit:mipit_secret@postgres:5432/mipit
RABBITMQ_URL=amqp://mipit:mipit_secret@rabbitmq:5672/mipit
JWT_SECRET=mipit-poc-jwt-secret-change-in-production
OTEL_EXPORTER_OTLP_ENDPOINT=http://jaeger:4318
OTEL_SERVICE_NAME=mipit-core
LOG_LEVEL=info
# HTTP rate limiter — bump on hosts that run the load suite to avoid 429s.
HTTP_RATE_LIMIT_MAX=5000
HTTP_RATE_LIMIT_WINDOW_MS=60000
UI_PROXY_PIX_HEALTH_URL=http://adapter-pix:9101/health
UI_PROXY_SPEI_HEALTH_URL=http://adapter-spei:9102/health
UI_PROXY_BREB_HEALTH_URL=http://adapter-breb:9103/health
UI_PROXY_PIX_MOCK_BASE_URL=http://adapter-pix:9001
UI_PROXY_SPEI_MOCK_BASE_URL=http://adapter-spei:9002
UI_PROXY_BREB_MOCK_BASE_URL=http://adapter-breb:9003
