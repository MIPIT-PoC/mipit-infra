NODE_ENV=development
RABBITMQ_URL=amqp://mipit:mipit_secret@rabbitmq:5672/mipit
QUEUE_NAME=payments.route.spei
ACK_ROUTING_KEY=ack.spei
EXCHANGE_NAME=mipit.payments
SPEI_SANDBOX_URL=http://localhost:9002
SPEI_MODE=mock
# Pin the simulated random rejection rate (0.0-1.0). Default 0.095.
MOCK_REJECTION_RATE=0.095
OTEL_EXPORTER_OTLP_ENDPOINT=http://jaeger:4318
OTEL_SERVICE_NAME=mipit-adapter-spei
LOG_LEVEL=info
